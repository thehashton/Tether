{
  "name": "demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"tsx server/index.ts\" \"next dev\"",
    "dev:vercel": "vercel dev",
    "dev:next": "next dev",
    "build": "pnpm --filter tether-ws build && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/functions": "^3.7.1",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tether-ws": "workspace:*",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.17",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "^4.0.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
